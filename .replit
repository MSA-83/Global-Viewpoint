modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["gh"]

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 8083
externalPort = 3001

[[ports]]
localPort = 8084
externalPort = 5000

[[ports]]
localPort = 8085
externalPort = 6800

[[ports]]
localPort = 25008
externalPort = 3000

[[ports]]
localPort = 25009
externalPort = 3002

[[ports]]
localPort = 25010
externalPort = 4200

[[ports]]
localPort = 25011
externalPort = 5173

[[ports]]
localPort = 25012
externalPort = 6000

[[ports]]
localPort = 25013
externalPort = 8008

[[ports]]
localPort = 25014
externalPort = 8000

[[ports]]
localPort = 25015
externalPort = 8081

[[ports]]
localPort = 25016
externalPort = 8099
